#include <iostream>
#include <string>

using namespace std;


void ReverseMain(const string& str, int index)
{
    if (index < 0)
    {
        return;
    }

    cout << str[index];

    ReverseMain(str, index - 1);
}



void ReverseTail(const string& str, int index, string result)
{
    if (index < 0)
    {
        cout << result;
        return;
    }

    ReverseTail(str, index - 1, result + str[index]);
}


int main()
{
    string str;

    cout << "Введіть строку: ";
    cin >> str;

    cout << "Головна рекурсія: ";
    ReverseMain(str, str.length() - 1);

    cout << endl;

    cout << "Хвостова рекурсія: ";
    ReverseTail(str, str.length() - 1, "");

    cout << endl;

    return 0;
}
