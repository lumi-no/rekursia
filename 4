#include <iostream>

using namespace std;


int ClimbStairsMain(int n)
{
    if (n == 1)
    {
        return 1;
    }

    if (n == 2)
    {
        return 2;
    }

    return ClimbStairsMain(n - 1) + ClimbStairsMain(n - 2);
}


int ClimbStairsTail(int n, int a = 1, int b = 2)
{
    if (n == 1)
    {
        return a;
    }

    if (n == 2)
    {
        return b;
    }

    return ClimbStairsTail(n - 1, b, a + b);
}


int main()
{
    int n;

    cout << "Введіть кількість сходинок: ";
    cin >> n;

    if (n < 1 || n > 45)
    {
        cout << "Помилка! n повинно бути в межах від 1 до 45.";

        return 0;
    }

    cout << endl;

    int resultMain = ClimbStairsMain(n);

    cout << "Головна рекурсія: ";
    cout << resultMain << endl;


    int resultTail = ClimbStairsTail(n);

    cout << "Хвостова рекурсія: ";
    cout << resultTail << endl;

    return 0;
}
